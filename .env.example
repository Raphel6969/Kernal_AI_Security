# AI Bouncer Configuration
# Copy this file to .env and customize values for your environment

# Kernel Monitoring Ownership
# Options: 'backend' (default), 'agent', 'disabled'
# Determines which process owns and manages kernel eBPF monitoring.
# Set to 'backend' if running backend service.
# Set to 'agent' if running the always-on agent service.
KERNEL_MONITOR_OWNER=backend

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Frontend CORS Origins
# Comma-separated list of allowed origins for frontend connections
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Event Storage
# Path to SQLite database file (relative or absolute)
# If not set, defaults to data/events.db in project root
DB_PATH=data/events.db

# Event Cache Size
# Maximum number of events to keep in memory cache
EVENT_CACHE_SIZE=1000

# Agent Settings
# Backend URL for agent to forward events to
BACKEND_URL=http://localhost:8000

# Event forwarding timeout (seconds)
AGENT_EVENT_TIMEOUT=5
